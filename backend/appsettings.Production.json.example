{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "your-api.azurewebsites.net;api.yourdomain.com",
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_DB_HOST;Port=5432;Database=eliteapp_prod;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
  },
  "Database": {
    "RunMigrations": true
  },
  "Jwt": {
    "Key": "CHOOSE_A_LONG_SECURE_RANDOM_KEY_AT_LEAST_32_CHARACTERS"
  },
  "Cors": {
    "AllowedOrigins": "https://your-web-app.com;https://admin.yourdomain.com"
  },
  "Security": {
    "MinPasswordLength": 8
  },
  "PasswordReset": {
    "Pepper": "STRONG_SECRET_PEPPER_FOR_HASHING",
    "TokenExpiryHours": 1
  },
  "Email": {
    "FromName": "Elite Services",
    "FromAddress": "charlie@elitehomeservicesusa.com",
    "PasswordResetSubject": "Reset your Elite password",
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": "587",
      "User": "charlie@elitehomeservicesusa.com",
      "Password": "YOUR_SMTP_APP_PASSWORD"
    }
  },
  "Legal": {
    "SupportEmail": "support@eliteservices.com"
  },
  "Sms": {
    "ContactPhone": "+19044311127",
    "Twilio": {
      "AccountSid": "YOUR_TWILIO_ACCOUNT_SID",
      "AuthToken": "YOUR_TWILIO_AUTH_TOKEN"
    }
  },
  "Bootstrap": {
    "AdminPassword": "CHANGE_ME_TO_A_SECURE_ADMIN_PASSWORD"
  },
  "ApplicationInsights": {
    "InstrumentationKey": "YOUR_APP_INSIGHTS_KEY_OPTIONAL"
  }
}
