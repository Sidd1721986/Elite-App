{
  "routes": [
    {
      "route": "/*",
      "allowedRoles": ["anonymous", "authenticated"]
    }
  ],
  "redirects": [
    {
      "route": "https://elitehomeservicesusa.com/*",
      "redirect": "https://www.elitehomeservicesusa.com/{0}",
      "statusCode": 301
    }
  ],
  "responseOverrides": {
    "401": {
      "rewrite": "/index.html",
      "statusCode": 200
    },
    "404": {
      "rewrite": "/index.html",
      "statusCode": 404
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
