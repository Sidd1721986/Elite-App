# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env.prod

# Environment-specific config (contains production API URL — never commit)
# Copy src/config/env.example.ts → src/config/env.ts and fill in real values.
src/config/env.ts

# typescript
*.tsbuildinfo

# Native excludes
ios/build/
ios/Pods/
android/app/build/
android/.gradle/
android/build/
android/keystore.properties

# logs and images
*.log
*.png

# Backend / .NET
[Bb]in/
[Oo]bj/
backend/bin/
backend/obj/
*.db-shm
*.db-wal
backend/eliteapp*.db*
# local caches and pids
*_pid.txt
metro_cache/
.terminal_history
*.png
*.log

# Production and local-secret appsettings (never commit real credentials)
backend/appsettings.Production.json
backend/appsettings.Local.json

# debug files
minimal.js
debug_index.js
test_metro.js

# Accidental duplicate / local junk (do not commit)
* 2.lock
* 3.lock
package-lock 2.json
*_pid*.txt
build/
build-test.bundle
debug_codegen.json
agentDebugEarly.js
