# Copy to .env.prod in the repo root (same folder as docker-compose.prod.yml).
#   cp .env.prod.example .env.prod
# Fill every required value. .env.prod is gitignored.

ASPNETCORE_ENVIRONMENT=Production

# Required: semicolon-separated API hostnames (Host header). Must not be *.
AllowedHosts=your-api.azurewebsites.net

# Required in Production (Program.cs validates non-empty connection string)
ConnectionStrings__DefaultConnection=Host=YOUR_HOST;Port=5432;Database=eliteapp;Username=YOUR_USER;Password=YOUR_PASSWORD

# Required: at least 32 characters
Jwt__Key=REPLACE_WITH_AT_LEAST_32_CHARACTER_RANDOM_SECRET

# Required: strong secret; must not contain CHANGE_ME or REPLACE_ (startup check)
PasswordReset__Pepper=REPLACE_WITH_LONG_RANDOM_PEPPER_SECRET

# Required: semicolon-separated HTTPS origins (e.g. Expo web or your site)
Cors__AllowedOrigins=https://your-app.example.com

# Optional: SMTP for password-reset emails (without Host, reset may return 503 in Production)
Email__Smtp__Host=
Email__Smtp__Port=587
Email__Smtp__User=
Email__Smtp__Password=
Email__FromAddress=

# Optional: one-time bootstrap if no admin user exists yet (remove after first deploy)
# Bootstrap__AdminPassword=
