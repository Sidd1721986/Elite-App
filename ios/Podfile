ENV['PATH'] = "/usr/local/bin:/opt/homebrew/bin:#{ENV['PATH']}"
require_relative '../node_modules/react-native/scripts/react_native_pods'

platform :ios, '16.0'

prepare_react_native_project!

# Manual Autolinking Bypass for hanging CLI
def manual_use_native_modules!
  package = JSON.parse(File.read('../package.json'))
  dependencies = (package['dependencies'] || {}).merge(package['devDependencies'] || {})
  
  dependencies.each do |name, version|
    next if name == 'react-native'
    # Find podspec in node_modules
    podspec_path = Dir.glob("../node_modules/#{name}/*.podspec").first
    if podspec_path
      pod_name = File.basename(podspec_path, ".podspec")
      Pod::UI.puts "[Manual Autolink] Found #{name} (as #{pod_name})".green
      pod pod_name, :path => "../node_modules/#{name}"
    end
  end
  return { :reactNativePath => '../node_modules/react-native' }
end

target 'multiuserauthapp' do
  config = manual_use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => true
    )
    # Disable Explicit Modules (Definitive fix for Xcode 16 / Yoga errors)
    installer.aggregate_targets.each do |target|
      target.user_project.targets.each do |p_target|
        p_target.build_configurations.each do |config|
          config.build_settings['CLANG_ENABLE_EXPLICIT_MODULES'] = 'NO'
          # Make `@import Sentry` resolvable from the app target too (Sentry-Swift.h
          # references the _SentryPrivate module, which clang can't find unaided).
          config.build_settings['OTHER_CFLAGS'] = '$(inherited) -fmodule-map-file="${PODS_ROOT}/Sentry/Sources/Sentry/include/module.modulemap"'
        end
      end
      target.user_project.save
    end
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ENABLE_EXPLICIT_MODULES'] = 'NO'
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        # Fix Yoga / glog C++20 strict errors with Xcode 26
        if target.name == 'Yoga' || target.name == 'glog'
          config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        end
        # Fix Sentry compilation errors on Xcode 16 (SentryViewHierarchyProviderHelper.m uses
        # private UIKit API that changed). Exclude the file — disables view hierarchy in crash
        # reports but compiles cleanly. Also suppress non-fatal warnings.
        # Sentry 9.16 requires Xcode 16; just keep warnings from failing the build.
        if target.name == 'Sentry' || target.name == 'RNSentry'
          config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
          config.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        end
        # The generated Sentry-Swift.h does `@import _SentryPrivate;` but clang can't
        # locate that module on its own — point it at Sentry's module.modulemap explicitly.
        # Needed by Sentry itself AND any target that does `@import Sentry` (RNSentry).
        if target.name == 'Sentry' || target.name == 'RNSentry'
          sentry_modulemap = '${PODS_ROOT}/Sentry/Sources/Sentry/include/module.modulemap'
          config.build_settings['OTHER_CFLAGS'] = "$(inherited) -fmodule-map-file=\"#{sentry_modulemap}\""
        end
      end
    end

    # Fix: paths with spaces break `/bin/sh -c "$WITH_ENVIRONMENT $SCRIPT_PHASES_SCRIPT"` in Xcode 26.
    # Replace the unquoted invocation with properly quoted args so word-splitting doesn't occur.
    project_path = installer.pods_project.path.to_s + "/project.pbxproj"
    pbxproj = File.read(project_path)
    if pbxproj.include?('/bin/sh -c \\"$WITH_ENVIRONMENT $SCRIPT_PHASES_SCRIPT\\"')
      pbxproj.gsub!(
        '/bin/sh -c \\"$WITH_ENVIRONMENT $SCRIPT_PHASES_SCRIPT\\"',
        '\\"$WITH_ENVIRONMENT\\" \\"$SCRIPT_PHASES_SCRIPT\\"'
      )
      File.write(project_path, pbxproj)
      puts "[Podfile patch] Fixed Generate Specs path-spaces quoting for Xcode 26"
    end

    # Patch Sentry 9.16.1 nullability mismatch that errors on Xcode 16.2:
    # the setter param must be _Nullable to match the nullable startTimestamp declaration.
    sdk_internal = "#{installer.sandbox.root}/Sentry/Sources/Sentry/SentrySDKInternal.m"
    if File.exist?(sdk_internal)
      content = File.read(sdk_internal)
      patched = content.gsub(
        '+ (void)setStartTimestamp:(NSDate *)value',
        '+ (void)setStartTimestamp:(NSDate *_Nullable)value'
      )
      if content != patched
        File.chmod(0644, sdk_internal)
        File.write(sdk_internal, patched)
        puts "[Podfile patch] SentrySDKInternal.m setStartTimestamp nullability fixed"
      end
    end

    # Patch fmt/base.h to disable consteval on ALL Apple Clang (Xcode 26 has a bug with it)
    fmt_base_h = "#{installer.sandbox.root}/fmt/include/fmt/base.h"
    if File.exist?(fmt_base_h)
      content = File.read(fmt_base_h)
      patched = content.gsub(
        '#elif defined(__apple_build_version__) && __apple_build_version__ < 14000029L',
        '#elif defined(__apple_build_version__) // Patched: disable consteval on all Apple Clang (Xcode 26 bug)'
      )
      File.chmod(0644, fmt_base_h)
      File.write(fmt_base_h, patched)
      puts "[Podfile patch] fmt/base.h consteval disabled for Apple Clang"
    end
  end



end
