{
  "name": "multiuserauthapp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "prestart": "node scripts/ensure-node-version.cjs && node scripts/ensure-project-root.cjs && npm run metro:kill",
    "preinstall": "node scripts/ensure-node-version.cjs",
    "start": "react-native start --host 127.0.0.1 --port 8081",
    "start:device": "react-native start --host 0.0.0.0 --port 8081",
    "start:reset": "node scripts/ensure-project-root.cjs && npm run metro:kill && react-native start --reset-cache --host 127.0.0.1 --port 8081",
    "metro:kill": "lsof -nP -iTCP:8081 -sTCP:LISTEN -t 2>/dev/null | xargs kill -9 2>/dev/null || true",
    "metro:check": "curl -sf http://127.0.0.1:8081/status >/dev/null && echo 'Metro OK on 127.0.0.1:8081' || (echo 'Metro not reachable at http://127.0.0.1:8081/status — run npm start in another terminal' >&2; exit 1)",
    "start:fresh": "node scripts/ensure-project-root.cjs && npm run metro:kill && (watchman watch-del-all 2>/dev/null || true) && react-native start --reset-cache --host 127.0.0.1 --port 8081",
    "ios": "node scripts/ensure-project-root.cjs && react-native run-ios --simulator \"iPhone 17\" --port 8081",
    "ios:list": "react-native run-ios --list-devices",
    "ios:no-packager": "node scripts/ensure-project-root.cjs && react-native run-ios --no-packager --simulator \"iPhone 17\" --port 8081",
    "android": "react-native run-android",
    "clean": "npm run clean:metro && npm run clean:watchman",
    "clean:metro": "react-native start --reset-cache --host 127.0.0.1 --port 8081",
    "clean:watchman": "watchman watch-del-all",
    "clean:ios": "cd ios && rm -rf build DerivedData && cd ..",
    "clean:ios:all": "cd ios && rm -rf build DerivedData Pods Podfile.lock && cd ..",
    "lint": "eslint .",
    "test": "jest",
    "postinstall": "cd ios && pod install && cd ..",
    "clean:deps": "node scripts/remove-node-modules.cjs && rm -f package-lock.json && npm install"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native/community-cli-plugin": "0.76.9",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/stack": "^7.6.16",
    "@shopify/flash-list": "^2.3.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-document-picker": "^9.3.0",
    "react-native-fast-image": "^8.6.3",
    "react-native-gesture-handler": "~2.21.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-keychain": "^10.0.0",
    "react-native-paper": "^5.14.5",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "~4.10.0",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@react-native-community/cli": "15.1.3",
    "@react-native-community/cli-platform-android": "15.1.3",
    "@react-native-community/cli-platform-ios": "15.1.3",
    "@react-native/babel-preset": "0.76.9",
    "@react-native/eslint-config": "0.76.9",
    "@react-native/metro-config": "0.76.9",
    "@react-native/typescript-config": "0.76.9",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "18.3.1",
    "jest": "^30.2.0",
    "react-test-renderer": "18.3.1",
    "ts-jest": "^29.4.6",
    "typescript": "~5.7.2"
  },
  "private": true
}
